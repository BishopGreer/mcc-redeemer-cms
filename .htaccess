Options +FollowSymLinks -Indexes

AddType application/manifest+json .webmanifest

RewriteEngine On
RewriteBase /

# Block direct HTTP access to sensitive directories
RewriteRule ^(core|config|install|cache)(/|$) - [F,L]

# Allow direct access to public assets (css, js, images, etc.)
RewriteRule ^public/ - [L]

# Route everything else through the front controller
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]

# ── Compression ──────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE text/javascript application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/xml application/rss+xml
  AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2 application/font-woff
  # Don't compress already-compressed formats
  SetEnvIfNoCase Request_URI \.(?:gif|jpg|jpeg|png|webp|ico|gz|zip|bz2|woff|woff2)$ no-gzip dont-vary
  Header append Vary Accept-Encoding env=!no-gzip
</IfModule>

# ── Browser caching ───────────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # Images — 1 year
  ExpiresByType image/jpeg  "access plus 1 year"
  ExpiresByType image/png   "access plus 1 year"
  ExpiresByType image/gif   "access plus 1 year"
  ExpiresByType image/webp  "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon  "access plus 1 year"
  ExpiresByType image/vnd.microsoft.icon "access plus 1 year"

  # Fonts — 1 year
  ExpiresByType font/woff   "access plus 1 year"
  ExpiresByType font/woff2  "access plus 1 year"
  ExpiresByType application/font-woff  "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"

  # CSS & JS — 1 year (cache-busting via ?v=filemtime in base.php)
  ExpiresByType text/css                "access plus 1 year"
  ExpiresByType application/javascript  "access plus 1 year"
  ExpiresByType text/javascript         "access plus 1 year"

  # HTML — no client cache (PHP page cache handles server-side)
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ── Cache-Control headers ─────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # Static assets — immutable once deployed
  <FilesMatch "\.(ico|jpg|jpeg|png|gif|webp|svg|woff|woff2|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # HTML pages — no client cache
  <FilesMatch "\.php$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  # Remove ETags (avoids redundant conditional requests)
  Header unset ETag
</IfModule>

FileETag None
